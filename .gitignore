# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.eggs/
# NOTE: do NOT ignore a generic 'build/' — we use that directory for
# the PyInstaller spec, app_entry, and the build script (all tracked).
# Specific build artifacts (.venv-build/, build_temp/, .icns) are
# listed individually under "DMG / app bundle build artifacts" below.

# Virtual environments
.venv/
venv/
env/

# Runtime output
recordings/
*.wav
*.mp3
*.m4a
*.txt
*.summary.md

# macOS
.DS_Store

# DMG / app bundle build artifacts
*.dmg
build_temp/
build/.venv-build/
meeting_capture/assets/AppIcon.iconset/
meeting_capture/assets/AppIcon.icns

# IDEs
.idea/
.vscode/
*.swp

# Local secrets / env
.env
.env.local
